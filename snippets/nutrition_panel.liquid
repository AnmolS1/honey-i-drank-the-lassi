{% assign nutrition = product.metafields.custom.nutritional_content.value %}
<div class="nutrition-panel">
	<h3 class="nutrition-title">Nutrition Facts</h3>
	
	<div class="nutrition-toggle-container">
	<button class="nutrition-toggle" onclick="toggleNutrition()" aria-expanded="false">
		Ingredients
		<svg class="toggle-icon" width="12" height="8" viewBox="0 0 12 8" fill="none">
			<path d="M1 1L6 6L11 1" stroke="var(--c0)" stroke-width="2"/>
		</svg>
	</button>
	</div>
	
	<div class="nutrition-dropdown">
		<div class="nutrition-grid">
			<div class="nutrition-row">
				<span>Serving Size</span>
				<span class="nutrition-value">{{ nutrition.serving_size }}</span>
			</div>
			<div class="nutrition-row">
				<span>Calories</span>
				<span class="nutrition-value">{{ nutrition.calories }}</span>
			</div>
			<div class="nutrition-row main-row">
				<span>Total Fat</span>
				<span class="nutrition-value">{{ nutrition.macronutrients.total_fat.value }}</span>
			</div>
			<div class="nutrition-row main-row">
				<span>Total Carbohydrates</span>
				<span class="nutrition-value">{{ nutrition.macronutrients.total_carbohydrates.value }}</span>
			</div>
			<div class="nutrition-row sub-row">
				<span>Dietary Fiber</span>
				<span class="nutrition-value">{{ nutrition.macronutrients.total_carbohydrates.dietary_fiber }}</span>
			</div>
			<div class="nutrition-row sub-row">
				<span>Sugars</span>
				<span class="nutrition-value">{{ nutrition.macronutrients.total_carbohydrates.total_sugars }}</span>
			</div>
		</div>
	</div>
</div>

<style>
	.nutrition-panel {
		margin: 0 auto;
		font-family: 'Lalezar', sans-serif;
		width: 80%;
	}
	
	.nutrition-title {
		color: var(--c1);
		font-size: 2rem;
		text-align: center;
		text-transform: uppercase;
	}
	
	.nutrition-toggle-container {
		position: relative;
		padding-bottom: 0.75rem;
		border-bottom: 1px solid var(--c0);
		margin-bottom: 0.5rem;
	}
	
	.nutrition-toggle {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		background: transparent;
		border: none;
		color: var(--c0);
		font-weight: bold;
		font-size: 1.25rem;
		cursor: pointer;
		padding: 0.5rem 0;
		width: 100%;
		text-align: left;
		margin-bottom: 0.5rem;
	}
	
	.toggle-icon {
		transition: transform 0.3s ease;
	}
	
	.nutrition-toggle[aria-expanded="true"] .toggle-icon {
		transform: rotate(180deg);
	}
	
	.nutrition-dropdown {
		max-height: 0;
		overflow: hidden;
		transition: max-height 0.3s ease;
		font-size: 1.2rem;
	}
	
	.nutrition-toggle[aria-expanded="true"] + .nutrition-dropdown {
		max-height: 500px;
	}
	
	.nutrition-grid {
		display: flex;
		flex-direction: column;
	}
	
	.nutrition-row {
		display: flex;
		justify-content: space-between;
		padding: 0.5rem 0;
		border-bottom: 1px solid var(--c0);
		color: var(--c1);
	}
	
	.main-row {
		font-weight: bold;
	}
	
	.sub-row {
		padding-left: 1.5rem;
		font-size: 1.1rem;
	}
	
	.nutrition-value {
		color: var(--c0);
		font-weight: bold;
	}
	
	@media (min-width: 770px) {
		.nutrition-panel {
			margin-top: 2rem;
		}
	}
</style>

<script>
function toggleNutrition() {
	const toggle = document.querySelector('.nutrition-toggle');
	const expanded = toggle.getAttribute('aria-expanded') === 'true';
	toggle.setAttribute('aria-expanded', !expanded);
	
	// Force reflow for smooth animation
	const dropdown = document.querySelector('.nutrition-dropdown');
	if (!expanded) {
		dropdown.style.display = 'block';
		const height = dropdown.scrollHeight;
		dropdown.style.maxHeight = height + 'px';
	} else {
		dropdown.style.maxHeight = '0';
		dropdown.addEventListener('transitionend', function() {
			if (dropdown.style.maxHeight === '0px') {
				dropdown.style.display = 'none';
			}
		}, { once: true });
	}
}
</script>