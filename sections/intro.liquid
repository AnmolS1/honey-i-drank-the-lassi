{% comment %} intro.liquid {% endcomment %}
<div class="intro">
	<div class="intro-tagline">From your roots to your reps</div>
	
	<br>
	
	<div class="intro-logo">
		<img src="{{ 'gm_logo_full.png' | asset_url }}" width="150" height="auto">
	</div>
	
	<br>
	<br>
	
	<div class="intro-grid">
		<div class="grid-item">
			<div class="grid-image">
				<img src="{{ 'intro_img_1.svg' | asset_url }}" width="100" height="100" loading="lazy" alt="Roots icon" class="grid-img">
			</div>
			<div class="grid-text">
				Flavors You Grew Up With
			</div>
		</div>
		
		<div class="grid-item">
			<div class="grid-image">
				<img src="{{ 'intro_img_2.svg' | asset_url }}" width="100" height="100" loading="lazy" alt="Ingredients icon" class="grid-img">
			</div>
			<div class="grid-text">
				Macros You Grew Into
			</div>
		</div>
		
		<div class="grid-item">
			<div class="grid-image">
				<img src="{{ 'intro_img_3.svg' | asset_url }}" width="100" height="100" loading="lazy" alt="Science icon" class="grid-img">
			</div>
			<div class="grid-text">
				&lt;1g Sugar
			</div>
		</div>
		
		<div class="grid-item">
			<div class="grid-image">
				<img src="{{ 'intro_img_4.svg' | asset_url }}" width="100" height="100" loading="lazy" alt="Community icon" class="grid-img">
			</div>
			<div class="grid-text">
				No Fake Stuff = No Bloat
			</div>
		</div>
	</div>
	
	<br>
	<br>
	
	<a href="{{ routes.all_products_collection_url }}" class="shop-now-btn">
		<span class="shop-now-btn__shadow"></span>
		<span class="shop-now-btn__main">
			<span class="shop-now-btn__text">SHOP NOW</span>
		</span>
	</a>
</div>

{% stylesheet %}
	.intro {
		margin-top: 2rem;
		margin-bottom: 2rem;
		background-color: #FAECD7;
		display: flex;
		flex-direction: column;
		align-items: center;
	}
	
	.intro-tagline {
		font-family: 'Lalezar';
		font-style: normal;
		font-weight: 400;
		font-size: 1rem;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: #004AAD;
	}
	
	.intro-logo img {
		margin: 0 auto;
		width: 80%;
	}
	
	.intro-grid {
		display: grid;
		grid-template-columns: auto 1fr;
		column-gap: 1rem;
		align-items: center;
	}
	
	.grid-item {
		display: contents; /* children participate in grid */
		left: 50%;
	}
	
	.grid-image {
		grid-column: 1;
		display: flex;
		justify-content: flex-end;
	}
	
	.grid-text {
		grid-column: 2;
		text-align: left;
		font-size: 1.1rem;
		font-family: 'Lalezar';
		font-style: normal;
		font-weight: 600;
		line-height: 0px;
		display: flex;
		align-items: center;
		letter-spacing: 0.1em;
		text-transform: capitalize;
		color: #F27141;
	}
	
	.grid-img {
		width: 35px;
		height: 35px;
		object-fit: contain;
	}
	
	.shop-now-btn {
		width: 10%;
	}
	
	@media (min-width: 769px) {
		.intro {
			width: 50%;
		}
		
		.intro-grid {
			row-gap: 0;
			column-gap: 1rem;
			margin: 1rem;
			width: 65%;
			height: 200px;
			background: white;
			border: 6px solid #FDDEE7;
			border-radius: 1.5rem;
			
			box-shadow:
				-4px 4px 0 4px #F293A0,
				-7px 7px 0 7px #F62D93,
				-10px 10px 0 10px #195BB4;

			grid-template-columns: .25fr 1fr;
		}
		
		.intro-tagline {
			font-size: 1.5rem;
		}
		
		.intro-logo {
			width: 60%;
		}
		
		.grid-image {
			width: 100%;
		}
		
		.grid-img {
			margin-left: 25%;
			width: 30px;
			height: 30px;
		}
		
		.grid-text {
			font-size: 1.5vw;
		}
	}
	
	@media (min-width: 990px) {
		.intro-grid {
			grid-template-columns: 0.35fr 1fr;
		}
		
		.grid-text {
			font-size: 1.25vw;
		}
		
		.grid-img {
			margin-left: 25%;
			width: 40px;
			height: 40px;
		}
	}
{% endstylesheet %}

