<header>
	<div class="header__logo">
		{% if section.settings.logo %}
			{% assign logo_height = section.settings.logo_height | default: 40 %}
			<a href="{{ routes.root_url }}">
				{{ section.settings.logo | image_url: width: 300 | image_tag:
					height: logo_height,
					width: section.settings.logo_width,
					alt: shop.name,
					class: 'header__logo-image',
					loading: 'eager'
				}}
			</a>
		{% else %}
			<h2 class="header__title">
				{{ shop.name | link_to: routes.root_url }}
			</h2>
		{% endif %}
	</div>
	
	<div class="header__menu">
		{% for link in section.settings.menu.links %}
			{{ link.title | link_to: link.url }}
		{% endfor %}
	</div>
	
	<div class="header__icons">
		{% if shop.customer_accounts_enabled %}
			{{ 'icon-account.svg' | inline_asset_content | link_to: routes.account_url }}
		{% endif %}
		
		<a href="{{ routes.cart_url }}">
			{% if cart.item_count > 0 %}
				<sup>{{ cart.item_count }}</sup>
			{% endif %}
			{{ 'gm_cart.svg' | inline_asset_content }}
		</a>
	</div>
</header>

{% stylesheet %}
	header {
		height: 5rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0 var(--page-margin);
	}
	header a {
		position: relative;
		text-decoration: none;
		color: var(--color-foreground);
	}
	header a sup {
		position: absolute;
		left: 100%;
		overflow: hidden;
		max-width: var(--page-margin);
	}
	header svg {
		width: 2rem;
	}
	header .header__menu,
	header .header__icons {
		display: flex;
		gap: 1rem;
	}
	.header__logo-image {
		height: auto;
		max-height: 100%;
		width: auto;
		max-width: 200px;
	}
	.header__title {
		margin: 0;
	}
	
	.header__menu a {
		position: relative;
		display: inline-block;
		padding: 0 0 0.28125rem;
		font-family: 'Lalezar', sans-serif;
		font-weight: 400;
		font-size: 2.25rem;
		line-height: 1.1;
		color: #F62D93;
		text-transform: uppercase;
		letter-spacing: 0.0703125rem;
	}
	
	.header__menu a::after {
		content: '';
		position: absolute;
		bottom: 0;
		left: 0;
		width: 0;
		height: 2px;
		background: #F62D93;
		transition: width 0.3s ease;
	}

	.header__menu a:hover::after {
		width: 45px;
	}
{% endstylesheet %}

{% schema %}
{
	"name": "t:general.header",
	"settings": [
		{
			"type": "link_list",
			"id": "menu",
			"label": "t:labels.menu"
		},
		{
			"type": "image_picker",
			"id": "logo",
			"label": "Logo image"
		},
		{
			"type": "range",
			"id": "logo_height",
			"min": 20,
			"max": 100,
			"step": 2,
			"unit": "px",
			"label": "Logo height",
			"default": 40
		},
		{
			"type": "range",
			"id": "logo_width",
			"min": 100,
			"max": 300,
			"step": 10,
			"unit": "px",
			"label": "Logo width (max)",
			"default": 200
		}
	]
}
{% endschema %}