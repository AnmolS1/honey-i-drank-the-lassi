<header>
	<div class="header__logo">
		{% if section.settings.logo %}
			{% assign logo_height = section.settings.logo_height | default: 40 %}
			<a href="{{ routes.root_url }}">
				{{ section.settings.logo | image_url: width: 220 | image_tag:
					height: logo_height,
					width: section.settings.logo_width,
					alt: shop.name,
					class: 'header__logo-image',
					loading: 'eager'
				}}
			</a>
		{% else %}
			<h2 class="header__title">
				{{ shop.name | link_to: routes.root_url }}
			</h2>
		{% endif %}
	</div>
	
	<div class="header__menu">
		{% for link in section.settings.menu.links %}
			{{ link.title | link_to: link.url }}
		{% endfor %}
	</div>
	
	<div class="header__icons">
		<a href="{{ routes.all_products_collection_url }}" class="shop-now-btn">
			<span class="shop-now-btn__shadow"></span>
			<span class="shop-now-btn__main">
				<span class="shop-now-btn__text">SHOP NOW</span>
			</span>
		</a>
		
		<a href="{{ routes.cart_url }}" class="header__cart">
			{% if cart.item_count > 0 %}
				<sup>{{ cart.item_count }}</sup>
			{% endif %}
			{{ 'gm_cart.svg' | inline_asset_content }}
		</a>
	</div>
</header>

{% stylesheet %}
	header {
		height: 7.5rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0 var(--page-margin);
		padding: 0 var(--page-margin);
	}
	header a {
		position: relative;
		text-decoration: none;
		color: var(--color-foreground);
	}
	header a sup {
		position: absolute;
		left: 100%;
		overflow: hidden;
		max-width: var(--page-margin);
	}
	header svg {
		width: 2rem;
	}
	header .header__menu, header .header__icons {
		display: flex;
		align-items: center;
	}
	header .header__menu {
		gap: max(1rem, 4vw);
	}
	header .header__icons {
		gap: 2rem;
	}
	.header__logo-image {
		height: auto;
		max-height: 100%;
		width: auto;
		max-width: 200px;
	}
	.header__title {
		margin: 0;
	}
	
	.header__menu a {
		padding: 0 0 0.28125rem;
		font-family: 'Lalezar', sans-serif;
		font-weight: 400;
		font-size: 3rem;
		line-height: 1;
		color: #F62D93;
		text-transform: uppercase;
		letter-spacing: 0.0703125rem;
	}
	
	.header__menu a::after {
		content: '';
		position: absolute;
		bottom: 0;
		left: 0;
		width: 0;
		height: 2px;
		background: #F62D93;
		transition: width 0.3s ease;
	}
	
	.header__menu a:hover::after {
		width: 45px;
	}
	
	.shop-now-btn {
		position: relative;
		display: inline-block;
		width: 100%;
		min-width: 250px;
		height: 80px;
		text-decoration: none;
	}
	
	.shop-now-btn__shadow {
		position: absolute;
		width: 100%;
		height: 100%;
		background: #2E65C2;
		border-radius: 20px;
		bottom: -4.5px;
		right: -9px;
		z-index: 1;
	}
	
	.shop-now-btn__main {
		position: absolute;
		width: 100%;
		height: 100%;
		background: #F62D93;
		border-radius: 20px;
		display: flex;
		align-items: center;
		justify-content: center;
		z-index: 2;
		top: -4.5px;
		transition: transform 0.2s ease;
	}
	
	.shop-now-btn:hover .shop-now-btn__main {
		transform: translate(-3px, -3px);
	}
	
	.shop-now-btn__text {
		font-family: 'Lalezar', sans-serif;
		font-size: 33px;
		line-height: 1;
		color: #F4E6D2;
		letter-spacing: 0.5px;
		text-transform: uppercase;
	}
	
	.header__cart svg {
		width: 3.5rem;
	}
	.header__logo-image {
		height: auto;
		max-height: 100%;
		width: auto;
		max-width: 200px;
	}
	.header__title {
		margin: 0;
	}
	
	.header__menu a {
		position: relative;
		display: inline-block;
		padding: 0 0 0.28125rem;
		font-family: 'Lalezar', sans-serif;
		font-weight: 400;
		font-size: 2.25rem;
		line-height: 1.1;
		color: #F62D93;
		text-transform: uppercase;
		letter-spacing: 0.0703125rem;
	}
	
	.header__menu a::after {
		content: '';
		position: absolute;
		bottom: 0;
		left: 0;
		width: 0;
		height: 2px;
		background: #F62D93;
		transition: width 0.3s ease;
	}

	.header__menu a:hover::after {
		width: 45px;
	}
{% endstylesheet %}

{% schema %}
{
	"name": "t:general.header",
	"settings": [
		{
			"type": "link_list",
			"id": "menu",
			"label": "t:labels.menu"
		},
		{
			"type": "image_picker",
			"id": "logo",
			"label": "Logo image"
		},
		{
			"type": "range",
			"id": "logo_height",
			"min": 20,
			"max": 100,
			"step": 2,
			"unit": "px",
			"label": "Logo height",
			"default": 40
		},
		{
			"type": "range",
			"id": "logo_width",
			"min": 100,
			"max": 300,
			"step": 10,
			"unit": "px",
			"label": "Logo width (max)",
			"default": 220
		}
	]
}
{% endschema %}

