{% comment %} header.liquid {% endcomment %}
<header>
	<div class="header__logo">
		{% if section.settings.logo %}
			{% assign logo_height = section.settings.logo_height | default: 40 %}
			<a href="{{ routes.root_url }}">
				{{ section.settings.logo | image_url: width: 220 | image_tag:
					height: logo_height,
					width: section.settings.logo_width,
					alt: shop.name,
					class: 'header__logo-image',
					loading: 'eager'
				}}
			</a>
		{% else %}
			<h2 class="header__title">
				{{ shop.name | link_to: routes.root_url }}
			</h2>
		{% endif %}
	</div>
	
	<div class="menu-container">
		<nav class="desktop_menu">
			{% for link in section.settings.menu.links %}
				{{ link.title | link_to: link.url }}
			{% endfor %}
		</nav>
		
		<nav class="mobile_menu" style="display: none;">
			{% for link in section.settings.menu.links %}
				{{ link.title | link_to: link.url }}
			{% endfor %}
		</nav>
	</div>
	
	<div class="header__icons">
		<button class="mobile-menu-toggle" aria-label="Toggle menu" aria-expanded="false">
			<span class="hamburger"></span>
		</button>
		
		<a href="{{ routes.all_products_collection_url }}" class="shop-now-btn">
			<span class="shop-now-btn__shadow"></span>
			<span class="shop-now-btn__main">
				<span class="shop-now-btn__content">
					<span class="shop-now-btn__text">SHOP NOW</span>
				</span>
			</span>
		</a>
		
		<a href="{{ routes.cart_url }}" class="header__cart">
			{% if cart.item_count > 0 %}
				<sup>{{ cart.item_count }}</sup>
			{% endif %}
			{{ 'gm_cart.svg' | inline_asset_content }}
		</a>
	</div>
</header>

{% stylesheet %}
	/* ===== MOBILE ===== */
	/* base styles */
	header {
		height: 6rem;
		display: flex;
		/* flex-wrap: wrap; allows row breaking, might not need */
		align-items: center;
		justify-content: space-between;
		padding: 0;
		position: relative;
	}
	
	/* logo */
	.header__logo {
		margin-right: auto;
	}
	
	.header__logo-image {
		height: auto;
		max-height: 3.5rem;
		width: auto;
		max-width: 200px;
	}
	
	/* mobile menu's default state */
	.desktop_menu {
		display: none; /* hidden on mobile */
	}
	
	.mobile_menu {
		display: none; /* hidden until toggled */
		position: fixed;
		top: 6rem;
		left: 0;
		width: 100%;
		height: calc(100% - 6rem);
		background: white;
		flex-direction: column;
		justify-content: space-evenly;
		padding: 2rem;
		z-index: 1000;
		box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
	}
	
	/* mobile toggle button */
	.mobile-menu-toggle {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		background: transparent;
		border: none;
		/* padding: 1rem; */
		cursor: pointer;
		z-index: 1001;
	}
	
	/* hamburger icon */
	.hamburger {
		position: relative;
		width: 30px;
		height: 3px;
		background: #6495ED;
		transition: all 0.3s ease;
	}
	
	.hamburger::before,
	.hamburger::after {
		content: '';
		position: absolute;
		left: 0;
		width: 30px;
		height: 3px;
		background: #6495ED;
		transition: all 0.3s ease;
	}
	
	.hamburger::before {
		transform: translateY(-8px);
	}
	
	.hamburger::after {
		transform: translateY(8px);
	}
	
	/* active states */
	.mobile-menu-toggle[aria-expanded="true"] .hamburger {
		background: transparent;
	}
	.mobile-menu-toggle[aria-expanded="true"] .hamburger::before {
		transform: rotate(45deg);
	}
	.mobile-menu-toggle[aria-expanded="true"] .hamburger::after {
		transform: rotate(-45deg);
	}
	
	.mobile-menu-toggle[aria-expanded="true"] + .menu-container .mobile-menu {
		display: flex;
	}
	
	/* shared menu link styles */
	.menu-container a {
		position: relative;
		display: inline-block;
		padding: 0 0 0.28125rem;
		font-family: 'Lalezar', sans-serif;
		font-weight: 400;
		font-size: 2.25rem;
		line-height: 1.1;
		color: #F62D93;
		text-transform: uppercase;
		letter-spacing: 0.0703125rem;
		text-decoration: none;
	}
	
	.menu-container a::after {
		content: '';
		position: absolute;
		bottom: 0;
		left: 0;
		width: 0;
		height: 2px;
		background: #F62D93;
		transition: width 0.3s ease;
	}
	
	.menu-container a:hover::after {
		width: 45px;
	}
	
	/* mobile menu links */
	.mobile_menu a {
		padding: 0;
		text-align: center;
		width: 100%;
	}
	.mobile_menu a::after {
		transition: unset;
	}
	.mobile_menu a:hover::after {
		width: unset;
	}
	
	/* header icons */
	.header__icons {
		display: flex;
		gap: 1rem;
		align-items: center;
	}
	
	.header__cart {
		width: 2.5rem;
		min-width: 2.5rem;
		color: #2E65C2;
	}
	
	/* shop now button */
	.shop-now-btn {
		position: relative;
		display: inline-block;
		width: 100%;
		min-width: 135px;
		height: 2.75rem;
		text-decoration: none;
	}
	
	.shop-now-btn__shadow {
		position: absolute;
		width: 100%;
		height: 100%;
		background: #2E65C2;
		border-radius: 15px;
		bottom: -2.25px;
		right: -4.5px;
		z-index: 1;
	}
	
	.shop-now-btn__main {
		position: absolute;
		width: 100%;
		height: 100%;
		background: #F62D93;
		border-radius: 15px;
		display: flex;
		align-items: center;
		justify-content: center;
		z-index: 2;
		top: -4.5px;
		transition: transform 0.2s ease;
	}
	
	.shop-now-btn:hover .shop-now-btn__main {
		transform: translate(-3px, -3px);
	}
	
	.shop-now-btn__text {
		font-family: 'Lalezar', sans-serif;
		font-size: 1.5rem;
		line-height: 1;
		color: #FEEED3;
		letter-spacing: 0.5px;
		text-transform: uppercase;
	}
	
	/* ===== DESKTOP STYLES ===== */
	@media (min-width: 991px) {
		header {
			height: 7.5rem;
		}
		
		.menu-container {
			width: 100%;
		}
		
		.mobile-menu-toggle,
		.mobile_menu {
			display: none;
		}
		
		.desktop_menu {
			display: flex;
			justify-content: space-evenly;
			width: 100%;
		}
		
		.header__logo-image {
			max-height: 5.625rem;
		}
		
		/* larger shop now button on desktop */
		.shop-now-btn {
			min-width: 250px;
			height: 75px;
		}
		
		.shop-now-btn__shadow {
			top: 4.5px;
			left: 9px;
		}
		
		.shop-now-btn__text {
			font-size: 2rem;
		}
		
		.header__icons {
			gap: 3rem;
		}
		
		.header__cart svg {
			width: 3.5rem;
			min-width: 3.5rem;
		}
	}
{% endstylesheet %}

{% if template == 'product' and product.metafields.custom.color %}
	<style>
		:root {
			--product-color-dark: {{ product.metafields.custom.color.value[0] }};
			--product-color-med: {{ product.metafields.custom.color.value[1] }};
			--product-color-light: {{ product.metafields.custom.color.value[2] }};
		}
		
		.menu-container a {
			color: var(--product-color-med);
		}
		
		.hamburger, .hamburger::before, .hamburger::after {
			background: var(--product-color-med);
		}
		
		.shop-now-btn__main {
			background-color: var(--product-color-med);
		}
		.shop-now-btn__shadow {
			background-color: var(--product-color-light);
		}
		
		.header__cart path {
			color: var(--product-color-med);
		}
	</style>
{% endif %}

{% javascript %}
	document.addEventListener('DOMContentLoaded', function() {
		const toggle = document.querySelector('.mobile-menu-toggle');
		
		if (toggle) {
			toggle.addEventListener('click', function() {
				const expanded = this.getAttribute('aria-expanded') === 'true';
				this.setAttribute('aria-expanded', !expanded);
				
				const mobileMenu = document.querySelector('.mobile_menu');
				mobileMenu.style.display = !expanded ? 'flex' : 'none';
			})
		}
	})
{% endjavascript %}

{% schema %}
{
	"name": "t:general.header",
	"settings": [
		{
			"type": "link_list",
			"id": "menu",
			"label": "t:labels.menu"
		},
		{
			"type": "image_picker",
			"id": "logo",
			"label": "Logo image"
		},
		{
			"type": "range",
			"id": "logo_height",
			"min": 20,
			"max": 100,
			"step": 2,
			"unit": "px",
			"label": "Logo height",
			"default": 40
		},
		{
			"type": "range",
			"id": "logo_width",
			"min": 100,
			"max": 300,
			"step": 10,
			"unit": "px",
			"label": "Logo width (max)",
			"default": 220
		}
	]
}
{% endschema %}