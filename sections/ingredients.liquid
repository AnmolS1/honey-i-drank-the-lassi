<div class="ingredients-section">
	<h1>Clean Ingredients</h1>
</div>

{% stylesheet %}
	.ingredients-section {
		height: 250px;
		background-color: #F62D93;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
	}
	
	.ingredients-section h1 {
		text-transform: uppercase;
		font-family: 'Lalezar';
		color: #FAECD7;
	}

	@media (min-width: 990px) {
		.ingredients-section {
			height: 450px;
		}
		
		.ingredients-section h1 {
			font-size: 4rem;
		}
	}
{% endstylesheet %}

{% schema %}
{
	"name": "t:general.ingredients",
	"class": "shopify-section--full-width",
	"settings": []
}
{% endschema %}